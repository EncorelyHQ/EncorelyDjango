									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/me/",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "me", ""]
						}
					}
				},
				{
					"name": "Get User Vibe DNA",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
