								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/me/",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "me", ""]
						}
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"display_name\": \"Camilo Updated\",\n    \"bio\": \"Nueva biografía musical\",\n    \"city\": \"Bogotá\",\n    \"concert_mood\": \"vip\"\n}",
							"options": {
