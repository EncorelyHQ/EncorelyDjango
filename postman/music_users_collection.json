{
	"info": {
		"name": "Encorely - Music & Users API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"Encorely2024!\",\n    \"password_confirm\": \"Encorely2024!\",\n    \"display_name\": \"Test User\",\n    \"city\": \"Medellín\",\n    \"concert_mood\": \"moshpit\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register/",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register", ""]
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"Encorely2024!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login/",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login", ""]
						}
					}
				}
			]
		},
		{
			"name": "Music",
			"item": [
				{
					"name": "List Songs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/songs/",
							"host": ["{{base_url}}"],
							"path": ["api", "songs", ""]
						}
					}
				},
				{
					"name": "Filter Songs (Artist)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/songs/?artist=Bad Bunny",
							"host": ["{{base_url}}"],
							"path": ["api", "songs", ""],
							"query": [
								{
									"key": "artist",
									"value": "Bad Bunny"
								}
							]
						}
					}
				},
				{
					"name": "Register Swipe",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"song\": 1,\n    \"type\": \"RIGHT\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/swipes/",
							"host": ["{{base_url}}"],
							"path": ["api", "swipes", ""]
						}
					}
				},
				{
					"name": "My Swipes",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/swipes/my/",
							"host": ["{{base_url}}"],
							"path": ["api", "swipes", "my", ""]
						}
					}
				}
			]
		},
		{
